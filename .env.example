# NoCapCompute Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# PINATA IPFS CONFIGURATION (Required for cloud pinning)
# Get free keys at: https://pinata.cloud
# ==========================================
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET=your_pinata_secret_key_here

# ==========================================
# DATABASE CONFIGURATION (Optional)
# Defaults to SQLite if not set
# ==========================================
# DATABASE_URL=sqlite:///./dicompute.db
# For PostgreSQL (V2+):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/dicompute

# ==========================================
# BLOCKCHAIN CONFIGURATION
# ==========================================
# XDC_APOTHEM_RPC=https://rpc.apothem.network
# PRIVATE_KEY=your_wallet_private_key

# ==========================================
# OPTIONAL FEATURES
# ==========================================
# REDIS_URL=redis://localhost:6379/0
# WEBHOOK_SECRET=your_webhook_secret

# IPFS Configuration
IPFS_API_URL=http://localhost:5001/api/v0

# CORS Configuration (security - comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Local IPFS node (optional fallback)
LOCAL_IPFS_URL=http://localhost:5001/api/v0

# Server Configuration
PORT=8001
BACKEND_URL=http://localhost:8001
