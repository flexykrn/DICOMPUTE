# DICOMPUTE Daemon Configuration
# Copy this to .env and fill in your values

# === REQUIRED ===

# Provider's Ethereum private key (with 0x prefix)
# This is the wallet that will claim jobs and sign heartbeats
PROVIDER_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Provider's Ethereum address (0x prefix)
PROVIDER_ADDRESS=0xYourProviderAddress

# M2 Backend API URL
BACKEND_URL=http://localhost:8000

# Backend API key for authentication
BACKEND_API_KEY=your-api-key

# === BLOCKCHAIN (for read-only indexer) ===

# XDC Apothem RPC URL
RPC_URL=https://erpc.apothem.network

# Chain ID (51 = XDC Apothem)
CHAIN_ID=51

# JobEscrow contract address (from deployed-addresses.json)
JOB_ESCROW_ADDRESS=0x2Ff9B760510fc0aAd51a59f8aDA62F8B2631a075

# === DATABASE (for indexer persistence) ===

# PostgreSQL connection string (optional — indexer works without DB)
DATABASE_URL=postgres://dicompute:dicompute@localhost:5432/dicompute?sslmode=disable

# === DOCKER ===

# Docker socket path
DOCKER_HOST=unix:///var/run/docker.sock

# Docker network for containers
DOCKER_NETWORK=dicompute

# Path for job input/output data
DATA_VOLUME_PATH=/var/lib/dicompute/data

# === HEARTBEAT ===

# How often to send heartbeats
HEARTBEAT_INTERVAL=30s

# Number of heartbeats before completing job
HEARTBEAT_COUNT=6

# === RESOURCE LIMITS ===

# Maximum resources this provider offers
MAX_CPU_CORES=8
MAX_RAM_GIB=32
MAX_VRAM_GIB=16

# === LOGGING ===

LOG_LEVEL=info
