# DICOMPUTE Provider Daemon Configuration
# Copy this file to .env and fill in your values

# ============================================
# BLOCKCHAIN (Required)
# ============================================
RPC_URL=https://erpc.apothem.network
CHAIN_ID=51
JOB_ESCROW_ADDRESS=0x2Ff9B760510fc0aAd51a59f8aDA62F8B2631a075

# Provider wallet private key (must be registered on GPURegistry)
# Get test XDC from: https://faucet.apothem.network
PROVIDER_PRIVATE_KEY=0x...

# ============================================
# BACKEND API (Optional - for compatibility)
# ============================================
BACKEND_URL=http://localhost:8001
BACKEND_API_KEY=

# ============================================
# IPFS (Required for log uploads)
# ============================================
PINATA_JWT=eyJhbG...

# ============================================
# DOCKER (Required for container execution)
# ============================================
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK=dicompute
DATA_VOLUME_PATH=/var/lib/dicompute/data

# ============================================
# DATABASE (Optional - for indexer persistence)
# ============================================
DATABASE_URL=

# ============================================
# HEARTBEAT
# ============================================
HEARTBEAT_INTERVAL=30s
HEARTBEAT_COUNT=6

# ============================================
# RESOURCE LIMITS
# ============================================
MAX_CPU_CORES=8
MAX_RAM_GIB=32
MAX_VRAM_GIB=16

# Set to true if no GPU available (CPU-only mode)
MOCK_GPU=false

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info