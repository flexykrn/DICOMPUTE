# DICOMPUTE Provider Daemon Environment
# Copy this to .env and fill in your values

# ─── Blockchain ───
RPC_URL=https://erpc.apothem.network
CHAIN_ID=51
JOB_ESCROW_ADDRESS=0x2Ff9B760510fc0aAd51a59f8aDA62F8B2631a075
PROOF_RECEIPT_ADDRESS=0xb35EfE4E7071B1c7ce7f00CC7BB667cEc706DBa2

# Provider wallet (must be registered in GPURegistry with 0.1+ XDC stake)
PROVIDER_PRIVATE_KEY=0x...your_provider_private_key...
PROVIDER_ADDRESS=0x...your_provider_address...

# ─── Backend API (optional, daemon watches chain directly now) ───
BACKEND_URL=http://localhost:8001
BACKEND_API_KEY=optional-api-key

# ─── Docker ───
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_NETWORK=dicompute
DATA_VOLUME_PATH=/var/lib/dicompute/data

# ─── IPFS (Pinata) ───
PINATA_JWT=your_pinata_jwt_or_leave_blank

# ─── Heartbeat ───
HEARTBEAT_INTERVAL=30s
HEARTBEAT_COUNT=6

# ─── Resources ───
MAX_CPU_CORES=8
MAX_RAM_GIB=32
MAX_VRAM_GIB=16
MOCK_GPU=false

# ─── Logging ───
LOG_LEVEL=info
