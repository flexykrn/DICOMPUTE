# DICOMPUTE GPU Provider Configuration
# Copy this file to .env and fill in your values

# Provider private key (with 0x prefix)
PROVIDER_KEY=0x

# JobEscrow contract address (already deployed on XDC Apothem)
JOB_ESCROW_ADDRESS=0x2Ff9B760510fc0aAd51a59f8aDA62F8B2631a075

# Backend API URL (change to your machine's IP if provider runs on different machine)
BACKEND_URL=http://localhost:8000

# XDC Apothem RPC
RPC_URL=https://erpc.apothem.network
